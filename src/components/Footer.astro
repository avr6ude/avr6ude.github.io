<footer class="footer">
  <div class="footer-inner">
    <p>built with astro &middot; deployed on cloudflare &middot; no trackers</p>
    <a href="/rss.xml">rss</a>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xl);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-3xl);
  }
  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 480px) {
    .footer {
      padding: var(--space-md);
    }
    .footer-inner {
      flex-direction: column;
      text-align: center;
      font-size: 0.75rem;
    }
  }
  .footer-inner a {
    color: var(--color-text-muted);
  }
  .footer-inner a:hover {
    color: var(--color-accent);
  }
</style>
