---
import Badge from "./Badge.astro";

interface Props {
  tags: string[];
  class?: string;
}

const { tags, class: className } = Astro.props;
---

<div class:list={["tag-list", className]}>
  {tags.map((tag) => <Badge variant="tag">{tag}</Badge>)}
</div>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
</style>
