---
import Card from "./Card.astro";
import Badge from "./Badge.astro";
import TagList from "./TagList.astro";

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  readTime: string;
  slug: string;
  til?: boolean;
}

const { title, date, excerpt, tags, readTime, slug, til = false } = Astro.props;
const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/posts/${slug}/`} class="post-card-link">
  <Card class="post-card">
    <div class="post-card-header">
      <div class="post-card-meta">
        <time datetime={date.toISOString()}>{formatted}</time>
        {til && <Badge variant="til">TIL</Badge>}
        <TagList tags={tags} />
      </div>
      <span class="post-card-readtime">{readTime}</span>
    </div>
    <h3 class="post-card-title">{title}</h3>
    <p class="post-card-excerpt">{excerpt}</p>
  </Card>
</a>

<style>
  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .post-card-link:hover {
    text-decoration: none;
  }
  .post-card-link:hover :global(.card) {
    border-color: var(--color-text-muted);
  }
  .post-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }
  .post-card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-sm);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    min-width: 0;
  }
  .post-card-readtime {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .post-card-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }
  .post-card-excerpt {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  @media (max-width: 480px) {
    .post-card-header {
      flex-direction: column;
    }
    .post-card-title {
      font-size: 1.1rem;
    }
  }
</style>
