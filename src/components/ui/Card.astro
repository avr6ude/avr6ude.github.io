---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["card", className]}>
  <slot />
</div>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }
</style>
