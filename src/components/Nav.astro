<style>
  .nav {
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }
  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .nav-brand:hover {
    text-decoration: none;
  }
  .nav-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    animation: pulse 2s ease-in-out infinite;
  }
  .nav-links {
    display: flex;
    gap: var(--space-lg);
    font-size: 0.85rem;
  }
  .nav-links a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
</style>
