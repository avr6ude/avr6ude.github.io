---
import Badge from "../components/ui/Badge.astro";
import Card from "../components/ui/Card.astro";
import Divider from "../components/ui/Divider.astro";
import Base from "../layouts/Base.astro";

const projects = [
  {
    name: "Game of Slop",
    description: "Conway's Game of Life but every cell is AI-generated slop. Eight species with a predator-prey food chain fight for internet dominance. Windows 98 UI, boot sequence, CRT scanlines, scrolling news ticker.",
    tags: ["react", "typescript", "gamedev", "ai"],
    links: [
      { label: "Play", url: "https://slop.avrdu.de" },
      { label: "GitHub", url: "https://github.com/avr6ude/gameofslop" },
    ],
  },
  {
    name: "avrdu.de",
    description: "This place. Static blog built with Astro, deployed on Cloudflare. Zero client JS, flashy theme, partially assembled by a hallucinating language model.",
    tags: ["astro", "cloudflare"],
    links: [
      { label: "GitHub", url: "https://github.com/avr6ude/avrdu.de" },
    ],
  },
];
---

<Base title="Projects — avrdu.de">
  <div class="projects-page">
    <h1 class="page-title">Projects</h1>
    <p class="page-desc">Things I've built or am building.</p>

    <Divider />

    <div class="project-list">
      {projects.map((project) => (
        <Card class="project-card">
          <h2 class="project-name">{project.name}</h2>
          <p class="project-desc">{project.description}</p>
          <div class="project-meta">
            <div class="project-tags">
              {project.tags.map((tag) => <Badge variant="tag">{tag}</Badge>)}
            </div>
            <div class="project-links">
              {project.links.map((link) => (
                <a href={link.url} class="project-link" target="_blank" rel="noopener">{link.label} &rarr;</a>
              ))}
            </div>
          </div>
        </Card>
      ))}
    </div>
  </div>
</Base>

<style>
  .projects-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl);
  }
  .page-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-sm);
  }
  .page-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .project-links {
    display: flex;
    gap: var(--space-md);
  }
  .project-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .project-link:hover {
    color: var(--color-text);
  }
  .project-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: var(--space-xs);
  }
  .project-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-md);
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
</style>
